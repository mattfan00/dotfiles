{
    "layer": "top",
    "position": "bottom",
	"height": 30,
    "modules-left": ["sway/workspaces", "sway/mode"],
    "modules-right": ["network", "tray", "clock"],

	"sway/mode": {
		"format": "{}"
	},
    "clock": {
        "format": "{:%Y-%m-%d %H:%M}"
    },
    "network": {
        "format-wifi": "[wifi]",
        "format-disconnected": "[disconnected]"
    },
    "tray": {
        "spacing": 10
    }
}
